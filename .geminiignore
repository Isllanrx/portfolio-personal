public/*.jpg
public/*.jpeg
public/*.ico
public/*.svg
public/*.gif

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# System Files
.DS_Store
Thumbs.db
